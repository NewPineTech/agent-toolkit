{
  "name": "agent-toolkit",
  "private": true,
  "bin": {
    "agent-toolkit": "./packages/cli/bin/agent-toolkit.mjs",
    "atk": "./packages/cli/bin/agent-toolkit.mjs"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm --filter @agent-toolkit/server run dev",
    "dev:widget": "pnpm --filter @agent-toolkit/widget run dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "pnpm -r run lint",
    "test": "pnpm -r run test",
    "typecheck": "pnpm -r run typecheck",
    "storybook": "pnpm --filter @agent-toolkit/widget run storybook",
    "db:generate": "pnpm --filter @agent-toolkit/server exec drizzle-kit generate",
    "db:migrate": "pnpm --filter @agent-toolkit/server exec drizzle-kit migrate",
    "db:push": "pnpm --filter @agent-toolkit/server exec drizzle-kit push",
    "db:studio": "pnpm --filter @agent-toolkit/server exec drizzle-kit studio"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "devDependencies": {
    "@agent-toolkit/cli": "workspace:*",
    "prettier": "^3.8.3"
  }
}
