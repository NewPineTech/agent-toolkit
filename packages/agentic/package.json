{
  "name": "@agent-toolkit/agentic",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "dependencies": {
    "@langchain/core": "^1.1.46",
    "@langchain/google-vertexai": "^2.1.30",
    "@langchain/langgraph": "^1.3.0",
    "@langchain/langgraph-checkpoint": "^1.0.2",
    "@langchain/langgraph-cli": "^1.2.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.76"
  },
  "scripts": {
    "build": "tsc && node scripts/copy-prompt-assets.mjs",
    "dev": "langgraphjs dev --config langgraph.json --port 2025 --no-browser",
    "dev:server": "PORT=2024 node --env-file=../../.env --import tsx src/server.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
