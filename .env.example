# --- Server package ---
# Required
DATABASE_URL=postgresql://agent_toolkit:dev_password@localhost:5432/agent_toolkit
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
JWT_SECRET=your-jwt-secret-must-be-at-least-32-characters-long
REDIS_URL=redis://localhost:6379

# Optional (with defaults)
CORS_MAX_AGE=86400
HOST=0.0.0.0
LOG_LEVEL=info
NODE_ENV=development
PORT=3000
SESSION_TTL_MINUTES=30
SHUTDOWN_TIMEOUT_MS=30000

# Postgres (used by docker-compose)
POSTGRES_DB=agent_toolkit
POSTGRES_PASSWORD=dev_password
POSTGRES_PORT=5432
POSTGRES_USER=agent_toolkit

# Redis (used by docker-compose)
REDIS_PORT=6379

# Seed script (db:seed)
SEED_PROVIDER_AGENT_ID=your-ragflow-agent-id
SEED_PROVIDER_API_KEY=your-ragflow-api-key
SEED_PROVIDER_BASE_URL=https://your-ragflow-instance/

# LangGraph workspace example:
#   provider_type=langgraph
#   provider_agent_id=hr_assistant
#   provider_base_url=http://langgraph:2024 in Docker, or http://localhost:2024 from the host
#   provider_api_key can be any non-empty shared value until provider-side auth is enabled.

# --- Widget package ---
# Widget build (used by `pnpm --filter widget build`)
WIDGET_API_URL=http://localhost:3000

# --- Agentic LangGraph package ---
# Secret used by the HR assistant model wrapper. Leave empty for deterministic fallback behavior.
GEMINI_VERTEX_API_KEY=

# Shared LangGraph service key.
# Generate with: openssl rand -hex 32
LANGGRAPH_API_KEY=

# Docker ports for the first-party LangGraph runtime and LangGraph Studio dev server.
LANGGRAPH_PORT=2024
LANGSTUDIO_PORT=2025

# Optional provider/API keys.
RAGFLOW_API_KEY=

# --- LangSmith ---
LANGSMITH_API_KEY=
