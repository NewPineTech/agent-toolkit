# --- Server package ---
# Required
DATABASE_URL=postgresql://agent_toolkit:dev_password@localhost:5432/agent_toolkit
REDIS_URL=redis://localhost:6379
JWT_SECRET=your-jwt-secret-must-be-at-least-32-characters-long
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
# Required only for langgraph workspaces
GEMINI_API_KEY=
# Optional alternative for langgraph workspaces using Gemini through Vertex AI
GEMINI_VERTEX_API_KEY=
GEMINI_VERTEX_PROJECT=
GEMINI_VERTEX_LOCATION=global
# Optional: enables ai-recruitment MCP tools for langgraph workspaces
AI_RECRUITMENT_MCP_URL=http://localhost:3000/api/v1/mcp
AI_RECRUITMENT_MCP_AUTH_TOKEN=

# Postgres (used by docker-compose)
POSTGRES_DB=agent_toolkit
POSTGRES_USER=agent_toolkit
POSTGRES_PASSWORD=dev_password
POSTGRES_PORT=5432

# Redis (used by docker-compose)
REDIS_PORT=6379

# Seed script (db:seed)
SEED_PROVIDER_API_KEY=your-ragflow-api-key
SEED_PROVIDER_AGENT_ID=your-ragflow-agent-id
SEED_PROVIDER_BASE_URL=https://your-ragflow-instance/

# Optional (with defaults)
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info
SESSION_TTL_MINUTES=30
CORS_MAX_AGE=86400
SHUTDOWN_TIMEOUT_MS=30000
NODE_ENV=development

# --- Widget package ---
# Widget build (used by `pnpm --filter widget build`)
WIDGET_API_URL=http://localhost:3000
