# Required
DATABASE_URL=postgresql://agent_toolkit:dev_password@localhost:5432/agent_toolkit
REDIS_URL=redis://localhost:6379
JWT_SECRET=your-jwt-secret-must-be-at-least-32-characters-long
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Postgres (used by docker-compose)
POSTGRES_DB=agent_toolkit
POSTGRES_USER=agent_toolkit
POSTGRES_PASSWORD=dev_password
POSTGRES_PORT=5432

# Redis (used by docker-compose)
REDIS_PORT=6379

# Seed script (db:seed)
SEED_PROVIDER_API_KEY=your-ragflow-api-key
SEED_PROVIDER_AGENT_ID=your-ragflow-agent-id
SEED_PROVIDER_BASE_URL=https://your-ragflow-instance/

# Optional (with defaults)
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info
SESSION_TTL_MINUTES=30
CORS_MAX_AGE=86400
SHUTDOWN_TIMEOUT_MS=30000
NODE_ENV=development
