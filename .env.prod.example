# === Production Environment ===
# Copy to .env.prod and fill in real values.
# NEVER commit .env.prod — it contains secrets.

# --- Required secrets ---
JWT_SECRET=
ENCRYPTION_KEY=
GEMINI_API_KEY=
GEMINI_VERTEX_API_KEY=
GEMINI_VERTEX_PROJECT=
GEMINI_VERTEX_LOCATION=global
AI_RECRUITMENT_MCP_AUTH_TOKEN=
POSTGRES_PASSWORD=

# Generate secrets with:
#   openssl rand -hex 32

# --- Database ---
POSTGRES_DB=agent_toolkit
POSTGRES_USER=agent_toolkit

# --- Server ---
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info
NODE_ENV=production
SESSION_TTL_MINUTES=30
CORS_MAX_AGE=86400
SHUTDOWN_TIMEOUT_MS=30000
AI_RECRUITMENT_MCP_URL=

# --- Docker image tag ---
IMAGE_TAG=latest
