# === Production Environment ===
# Copy to .env.prod and fill in real values.
# NEVER commit .env.prod — it contains secrets.

# --- Required secrets ---
JWT_SECRET=
ENCRYPTION_KEY=
POSTGRES_PASSWORD=

# Generate secrets with:
#   openssl rand -hex 32

# --- Database ---
POSTGRES_DB=agent_toolkit
POSTGRES_USER=agent_toolkit

# --- Server ---
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info
NODE_ENV=production
SESSION_TTL_MINUTES=30
CORS_MAX_AGE=86400
SHUTDOWN_TIMEOUT_MS=30000

# --- Docker image tag ---
IMAGE_TAG=latest
