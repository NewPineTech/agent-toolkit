# === Production Environment ===
# Copy to .env.prod and fill in real values.
# NEVER commit .env.prod — it contains secrets.

# --- Required secrets ---
ENCRYPTION_KEY=
GEMINI_VERTEX_API_KEY=
JWT_SECRET=
POSTGRES_PASSWORD=

# Generate secrets with:
#   openssl rand -hex 32

# --- Database ---
POSTGRES_DB=agent_toolkit
POSTGRES_USER=agent_toolkit

# --- Server ---
CORS_MAX_AGE=86400
HOST=0.0.0.0
LOG_LEVEL=info
NODE_ENV=production
PORT=3000
SESSION_TTL_MINUTES=30
SHUTDOWN_TIMEOUT_MS=30000

# --- Docker image and widget build ---
IMAGE_TAG=latest
WIDGET_API_URL=

# --- Agentic LangGraph package ---
# Shared LangGraph service key.
# Generate with: openssl rand -hex 32
LANGGRAPH_API_KEY=
LANGGRAPH_PORT=2024
LANGSTUDIO_PORT=2025
RAGFLOW_API_KEY=

# --- LangSmith ---
LANGSMITH_API_KEY=

# --- AI recruitment MCP ---
AI_RECRUITMENT_MCP_AUTH_TOKEN=
AI_RECRUITMENT_MCP_SEARCH_LIMIT=3
AI_RECRUITMENT_MCP_TIMEOUT_MS=4000
AI_RECRUITMENT_MCP_URL=
